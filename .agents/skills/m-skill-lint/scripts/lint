#!/usr/bin/env python3
"""Validate skill directory structure and conventions."""

import os
import re
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
SKILL_DIR = SCRIPT_DIR.parent

def find_repo_root(start_path: Path) -> Path:
    for parent in [start_path] + list(start_path.parents):
        if (parent / ".git").exists() or (parent / "README.md").exists():
            return parent
    return start_path.parent.parent

REPO_ROOT = find_repo_root(SCRIPT_DIR)
SKILLS_ROOT = REPO_ROOT / "skills"
README = REPO_ROOT / "README.md"
DEFAULT_SKILLS = REPO_ROOT / "scripts" / "config" / "default-skills.txt"

EXIT_CODE = 0

RED = "\033[0;31m"
GREEN = "\033[0;32m"
YELLOW = "\033[0;33m"
NC = "\033[0m"


def p(label, text):
    print(f"  {label}{NC} {text}")


def pass_(text):
    p(f"{GREEN}PASS", text)


def fail(text):
    global EXIT_CODE
    p(f"{RED}FAIL", text)
    EXIT_CODE = 1


def warn(text):
    p(f"{YELLOW}WARN", text)


def validate_frontmatter(content: str) -> list[str]:
    """Parse and validate YAML frontmatter rules."""
    errors = []
    
    # 1. Delimiter checks
    lines = content.splitlines()
    if not lines or lines[0].strip() != "---":
        errors.append("SKILL.md missing or invalid YAML frontmatter starting delimiter")
        return errors
        
    end_idx = -1
    for i in range(1, len(lines)):
        if lines[i].strip() == "---":
            end_idx = i
            break
            
    if end_idx == -1:
        errors.append("SKILL.md missing YAML frontmatter ending delimiter")
        return errors
        
    # Check total character length of the frontmatter block
    first_delim = content.find("---")
    second_delim = content.find("---", first_delim + 3)
    if second_delim == -1:
        errors.append("SKILL.md missing YAML frontmatter ending delimiter")
        return errors
        
    fm_block = content[:second_delim + 3]
    if len(fm_block) > 1024:
        errors.append(f"YAML frontmatter section is too long ({len(fm_block)} chars, max 1024)")
        
    # 2. Parse key-value pairs
    parsed_fields = {}
    current_key = None
    
    fm_lines = lines[1:end_idx]
    for line in fm_lines:
        stripped = line.strip()
        if not line:
            if current_key:
                parsed_fields[current_key] += "\n"
            continue
        if stripped.startswith("#"):
            continue
            
        if line.startswith((" ", "\t")):
            if current_key:
                parsed_fields[current_key] += "\n" + stripped
            else:
                errors.append(f"Indented line outside of key: '{line}'")
        else:
            if ":" not in line:
                errors.append(f"Invalid line format in frontmatter (missing colon): '{line}'")
                continue
            key, val = line.split(":", 1)
            key = key.strip()
            val = val.strip()
            parsed_fields[key] = val
            current_key = key
            
    # 3. Check for unsupported fields
    allowed_fields = {"name", "description"}
    for key in parsed_fields:
        if key not in allowed_fields:
            errors.append(f"Unsupported field '{key}' in frontmatter")
            
    # 4. Check 'name' field
    if "name" not in parsed_fields:
        errors.append("Missing 'name' field in frontmatter")
    else:
        name_val = parsed_fields["name"]
        if not re.match(r"^[a-zA-Z0-9-]+$", name_val):
            errors.append(f"Field 'name' contains invalid characters: '{name_val}' (only letters, numbers, and hyphens allowed)")
            
    # 5. Check 'description' field
    if "description" not in parsed_fields:
        errors.append("Missing 'description' field in frontmatter")
    else:
        desc_val = parsed_fields["description"]
        desc_val = re.sub(r'^[>|]\s*', '', desc_val).strip()
        if not desc_val.lower().startswith("use when"):
            errors.append(f"Field 'description' must start with 'Use when...' (got '{desc_val[:30]}...')")
            
    return errors


def get_frontmatter_name(skill_md: Path) -> str | None:
    """Extract 'name:' value from YAML frontmatter."""
    content = skill_md.read_text(encoding="utf-8")
    lines = content.splitlines()
    if not lines or lines[0].strip() != "---":
        return None
    for line in lines[1:]:
        if line.strip() == "---":
            break
        if ":" in line:
            key, val = line.split(":", 1)
            if key.strip() == "name":
                return val.strip()
    return None


def skill_is_in_section(name: str, section_header: str) -> bool:
    """Check if a skill name appears between two section headers in README."""
    readme = README.read_text(encoding="utf-8")
    # Find the section range
    start = readme.find(section_header)
    if start == -1:
        return False
    # Find the next ## or ### header after this section
    rest = readme[start + len(section_header):]
    end = len(readme)
    for m in re.finditer(r"^#{1,3}\s", rest, re.MULTILINE):
        end = start + len(section_header) + m.start()
        break
    section_text = readme[start:end]
    return f"[{name}]" in section_text


def main():
    print("=== m-skill-lint: Skill Structure Validation ===\n")
    errors = []
    skill_dirs = sorted(SKILLS_ROOT.iterdir())

    for skill_path in skill_dirs:
        if not skill_path.is_dir():
            continue
        name = skill_path.name
        print(f"--- {name} ---")

        # 1. SKILL.md must exist
        skill_md = skill_path / "SKILL.md"
        if not skill_md.exists():
            fail(f"{name}: SKILL.md missing")
            errors.append(name)
            print()
            continue

        # 2. SKILL.md frontmatter
        content = skill_md.read_text(encoding="utf-8")
        fm_errors = validate_frontmatter(content)
        if fm_errors:
            for err in fm_errors:
                fail(f"{name}: {err}")
        else:
            pass_(f"{name}: SKILL.md has valid frontmatter")
            fm_name = get_frontmatter_name(skill_md)
            if fm_name == name:
                pass_(f"{name}: frontmatter name matches directory")
            else:
                fail(f"{name}: frontmatter name is '{fm_name}', expected '{name}'")

        # 3. Third-party vs first-party
        has_attribution = (skill_path / "ATTRIBUTION").exists()
        has_license = (skill_path / "LICENSE").exists()
        is_third = has_attribution or has_license

        if has_attribution:
            pass_(f"{name}: has ATTRIBUTION (third-party)")
            if has_license:
                pass_(f"{name}: has LICENSE for third-party")
            else:
                fail(f"{name}: missing LICENSE for third-party")
        elif has_license:
            fail(f"{name}: has LICENSE without ATTRIBUTION (origin undocumented)")
        else:
            pass_(f"{name}: no ATTRIBUTION (first-party)")
            pass_(f"{name}: no LICENSE (first-party)")

        # 4. README.md entry
        readme_entry = f"[{name}]"
        if readme_entry in README.read_text(encoding="utf-8"):
            pass_(f"{name}: has README.md entry")
            in_first = skill_is_in_section(name, "### First-Party Skills")
            in_third = skill_is_in_section(name, "### Third-Party Skills")
            if is_third:
                if in_third:
                    pass_(f"{name}: in Third-Party section")
                else:
                    fail(f"{name}: third-party but not in Third-Party section")
            else:
                if in_first:
                    pass_(f"{name}: in First-Party section")
                else:
                    fail(f"{name}: first-party but not in First-Party section")
        else:
            fail(f"{name}: missing README.md entry")

        print()

    # Default skills check
    print("=== Default Skills ===")
    if DEFAULT_SKILLS.exists():
        seen = set()
        for line in DEFAULT_SKILLS.read_text(encoding="utf-8").split("\n"):
            line = line.split("#")[0].strip()
            if not line:
                continue
            if line in seen:
                fail(f"default: duplicate entry '{line}'")
                continue
            seen.add(line)
            if (SKILLS_ROOT / line).is_dir():
                pass_(f"default: {line} exists")
            else:
                fail(f"default: {line} listed but directory missing")

    print()
    if EXIT_CODE == 0:
        print(f"{GREEN}All checks passed.{NC}")
    else:
        print(f"{RED}Some checks failed.{NC}")
    sys.exit(EXIT_CODE)


if __name__ == "__main__":
    main()
